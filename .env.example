# Supabase 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# 로컬에서 카카오 로그인 후 프로덕션으로 튕길 때: 아래에 dev URL 지정 + Supabase Authentication → URL Configuration
# → Redirect URLs에 `http://localhost:5199/` 및 `http://localhost:5199/**` 추가
# 폰에서 `http://PC내부IP:5199`로 접속해 테스트하면 같은 패턴으로 `http://192.168.x.x:5199/**`도 등록(OAuth 복귀는 `/login` 등 실제 경로로 감)
# VITE_AUTH_REDIRECT_URL=http://localhost:5199/
#
# 카카오 디벨로퍼스 → 앱 → 플랫폼 키(Default JS Key 등)
# - JavaScript SDK 도메인: 이 프로젝트 dev 포트는 vite 기준 5199 → `http://localhost:5199` (5173 아님), 폰 테스트 시 `http://PC내부IP:5199`
# - 카카오 로그인 Redirect URI: 공백 없이 `https://<VITE_SUPABASE_URL의 호스트>/auth/v1/callback` 한 줄 (Supabase 대시보드 API URL 복사 후 끝에 붙임)

# 데이터 모드: test(가상·데모) | real(실측 연동 전 — 지도 시뮬·데모 AI 비표시)
VITE_SPOTVIBE_DATA_MODE=test

# Groq AI — console.groq.com → API Keys
VITE_GROQ_API_KEY=
# Edge `ai-verify-spot-report`: Supabase → Edge Functions → Secrets 에 GROQ_API_KEY (선택 ADMIN_SPOT_REPORT_EMAIL, 기본 pwping83@gmail.com)
#
# Edge `phone-cert-callback`(휴대폰 본인확인 콜백 스켈레톤): Supabase → Edge Functions → Secrets
# PHONE_CERT_WEBHOOK_SECRET=임의 강한 문자열(콜백 POST 시 헤더 X-SpotVibe-Cert-Secret 와 동일해야 함)
# 업체(다날·KCP·PASS 등) 연동 시 업체가 요구하는 MID·암호키 등도 여기 Secrets에만 보관

# EmailJS(문의하기) — Account → API keys의 Public Key만 사용 (Private Key는 절대 프론트에 넣지 마세요)
# 대시보드에서「테스트 발송」이 되어도, 아래 세 값이 Vercel「Production」빌드에 없으면 앱은 mailto(이메일 전송)만 씁니다.
# 반드시 이름이 VITE_ 로 시작해야 하며, 변수 추가 후 Vercel에서 재배포(Redeploy)해야 반영됩니다.
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
# Public Key 자리에 대시보드의 User ID(공개 키와 동일)만 넣은 경우 대비 별칭(택1): VITE_EMAILJS_USER_ID=

# 사업자 정보 — 카카오 비즈니스 심사·/company·로그인 등 공개 고지. 등록증과 동일한 문자열만. Git 커밋 금지.
# 로컬 채우기: 루트의 `env.business.template` 를 복사해 `.env.local` 로 저장 후 값 입력 → dev 재시작.
# VITE_ 값은 빌드 후 브라우저에 포함됩니다.
# VITE_BUSINESS_TRADE_NAME=      상호(법인명)
# VITE_BUSINESS_REPRESENTATIVE=  대표자명
# VITE_BUSINESS_REG_NUMBER=      사업자등록번호(등록증과 동일)
# VITE_BUSINESS_INDUSTRY=        업태·종목(등록증 기재와 동일)
# VITE_BUSINESS_ADDRESS=          사업장 소재지
# VITE_BUSINESS_PHONE=            고객용 연락처(대표 전화 등)
# VITE_BUSINESS_EMAIL=           고객용 이메일
# VITE_BUSINESS_ECOMMERCE_REPORT_NUMBER=  통신판매업 신고번호(해당 없으면 비워 두거나 문구만)
VITE_BUSINESS_TRADE_NAME=
VITE_BUSINESS_REPRESENTATIVE=
VITE_BUSINESS_REG_NUMBER=
VITE_BUSINESS_INDUSTRY=
VITE_BUSINESS_ADDRESS=인천 중구 운북동 506-59, 대영라비앙로즈빌 제에이동 401호
VITE_BUSINESS_PHONE=
VITE_BUSINESS_EMAIL=
VITE_BUSINESS_ECOMMERCE_REPORT_NUMBER=

# 중소벤처24 「공고정보 연계 API」token 값 — https://www.smes.go.kr/main/dbCnrs (가이드 V2: 쿼리 파라미터명 token)
# 루트 `.env` 에만 저장. Git·채팅 공유 금지(유출 시 재발급). 증명서 일괄확인 API와는 별도 서비스입니다.
# SMES_EXT_PBLANC_KEY=

# Cursor MCP(@supabase/mcp-server-supabase): Windows 사용자 환경 변수 등에 설정
# SUPABASE_ACCESS_TOKEN=대시보드 우상단 계정 → Access Tokens → 새 토큰
